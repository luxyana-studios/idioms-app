EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat — leave empty to disable payments (FREE_TIER takes over)
EXPO_PUBLIC_REVENUECAT_KEY=

# Set to true to bypass all payment screens (free access)
EXPO_PUBLIC_FREE_TIER=false

# Dev shortcuts (only active in __DEV__ builds)
# Set to false to stop onboarding from resetting on every launch
EXPO_PUBLIC_DEV_RESET_ONBOARDING=true
# Set to true to skip onboarding entirely and jump straight to the main app
EXPO_PUBLIC_DEV_SKIP_ONBOARDING=false
