DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
OPENAI_API_KEY=sk-...

# Default model for any capability without an override below.
OPENAI_MODEL=gpt-4o-mini

# Per-capability overrides. Uncomment and set to spend extra LLM budget
# on the stages that matter most. See pipeline/CLAUDE.md > "Per-capability
# model setting" for guidance.
# OPENAI_MODEL_GENERATE_CANDIDATES=gpt-4o
# OPENAI_MODEL_SUGGEST_EQUIVALENTS=gpt-4o
# OPENAI_MODEL_ENRICH=
# OPENAI_MODEL_VERIFY=gpt-4o
# OPENAI_MODEL_TRANSLATE=
# OPENAI_MODEL_TRANSLATE_TAGS=
# OPENAI_MODEL_TAG=
